{
  "manifest_version": 3,
  "name": "YuzuTask",
  "version": "1.0.0",
  "description": "日系清新风的任务管理 & 番茄钟 & 工作记录新标签页",
  "permissions": [
    "storage",
    "alarms",
    "notifications"
  ],
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
